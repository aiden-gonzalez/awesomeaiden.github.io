---
import Layout from '../layouts/Layout.astro';

const primaryColors = [
  { name: '--color-bone',        hex: '#f5f1ea', note: 'Page background, light surfaces' },
  { name: '--color-bone-warm',   hex: '#faf6ed', note: 'Card surfaces (slightly lighter)' },
  { name: '--color-bone-shade',  hex: '#efe9da', note: 'Inset surfaces, headers, footers' },
  { name: '--color-bone-line',   hex: '#c4b896', note: 'Borders, dividers, dashed lines' },
  { name: '--color-forest',      hex: '#3a5a4a', note: 'Structural — contour lines, labels, metadata' },
  { name: '--color-forest-soft', hex: 'rgba(58, 90, 74, 0.55)', note: 'Softened forest for secondary marks' },
  { name: '--color-forest-faint',hex: 'rgba(58, 90, 74, 0.15)', note: 'Faint forest for backgrounds, washes' },
  { name: '--color-clay',        hex: '#8b3a2b', note: 'Accent — waypoints, active states' },
  { name: '--color-clay-tint',   hex: '#f5e4dc', note: 'Clay background for "active" badges' },
  { name: '--color-ink',         hex: '#2c2416', note: 'Body text, headings, hub center' },
  { name: '--color-ink-soft',    hex: '#6b5d44', note: 'Secondary text, captions' },
];

const semanticAliases = [
  { name: '--color-bg',             refs: '--color-bone' },
  { name: '--color-surface',        refs: '--color-bone-warm' },
  { name: '--color-surface-inset',  refs: '--color-bone-shade' },
  { name: '--color-border',         refs: '--color-bone-line' },
  { name: '--color-text-primary',   refs: '--color-ink' },
  { name: '--color-text-secondary', refs: '--color-forest' },
  { name: '--color-text-tertiary',  refs: '--color-ink-soft' },
  { name: '--color-accent',         refs: '--color-clay' },
];

const typeSizes = [
  { name: '--text-xs',   px: '11px', usage: 'mono labels' },
  { name: '--text-sm',   px: '13px', usage: 'secondary body' },
  { name: '--text-base', px: '15px', usage: 'body' },
  { name: '--text-lg',   px: '18px', usage: 'small headings' },
  { name: '--text-xl',   px: '22px', usage: 'section titles' },
  { name: '--text-2xl',  px: '28px', usage: 'sub-hero' },
  { name: '--text-3xl',  px: '36px', usage: 'hero' },
];

const trackingScale = [
  { name: '--tracking-tight',  value: '-0.02em', usage: 'Hero name, large display' },
  { name: '--tracking-normal', value: '0',       usage: 'Default body text' },
  { name: '--tracking-loose',  value: '0.05em',  usage: 'Mono labels' },
  { name: '--tracking-extra',  value: '0.15em',  usage: 'Tag pills, section markers' },
  { name: '--tracking-mega',   value: '0.25em',  usage: '"STARTING LINE"-style tags' },
];

const sampleText = 'The contour leaves the map. Made it. Thanks for hiking up. 47°36N / 122°20W.';
---

<Layout title="Design system — aidengonzalez.dev" description="Color, type, and motion tokens for the redesign.">
  <main>
    <header class="page-header">
      <p class="label-mono">section 00 — design system</p>
      <h1 class="page-title">Design system</h1>
      <p class="page-sub">
        Every color, type voice, and motion token from <code>design-tokens.css</code>, rendered so the system can be signed off before any feature work begins.
      </p>
    </header>

    <section class="block">
      <h2 class="block-title"><span class="label-mono">01</span> Primary palette</h2>
      <div class="swatch-grid">
        {primaryColors.map((c) => (
          <article class="swatch">
            <div class="swatch-fill" style={`background:${c.hex}`}></div>
            <div class="swatch-meta">
              <code class="swatch-name">{c.name}</code>
              <span class="swatch-hex">{c.hex}</span>
              <span class="swatch-note">{c.note}</span>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="block">
      <h2 class="block-title"><span class="label-mono">02</span> Semantic aliases</h2>
      <p class="block-intro">Aliases reference primary tokens — change a primary, every alias follows.</p>
      <ul class="alias-list">
        {semanticAliases.map((a) => (
          <li class="alias-row">
            <code class="alias-name">{a.name}</code>
            <span class="alias-arrow">→</span>
            <code class="alias-ref">{a.refs}</code>
            <span class="alias-chip" style={`background:var(${a.refs})`}></span>
          </li>
        ))}
      </ul>
    </section>

    <section class="block">
      <h2 class="block-title"><span class="label-mono">03</span> Type voices</h2>
      <p class="block-intro">Three voices in opposition: sans for content, mono for systems, serif italic for the field-journal moments.</p>

      <div class="voice-block">
        <h3 class="voice-label"><code>--font-sans</code> · Inter · body, headings, navigation</h3>
        {typeSizes.map((s) => (
          <div class="type-row">
            <code class="type-token">{s.name}</code>
            <span class="type-px">{s.px}</span>
            <span class="type-usage">{s.usage}</span>
            <p class="type-sample" style={`font-family:var(--font-sans); font-size:var(${s.name})`}>{sampleText}</p>
          </div>
        ))}
      </div>

      <div class="voice-block">
        <h3 class="voice-label"><code>--font-mono</code> · JetBrains Mono · labels, coordinates, metadata</h3>
        {typeSizes.map((s) => (
          <div class="type-row">
            <code class="type-token">{s.name}</code>
            <span class="type-px">{s.px}</span>
            <span class="type-usage">{s.usage}</span>
            <p class="type-sample" style={`font-family:var(--font-mono); font-size:var(${s.name})`}>{sampleText}</p>
          </div>
        ))}
      </div>

      <div class="voice-block">
        <h3 class="voice-label"><code>--font-serif</code> · Source Serif 4 (italic) · field-journal moments only</h3>
        {typeSizes.map((s) => (
          <div class="type-row">
            <code class="type-token">{s.name}</code>
            <span class="type-px">{s.px}</span>
            <span class="type-usage">{s.usage}</span>
            <p class="type-sample" style={`font-family:var(--font-serif); font-style:italic; font-size:var(${s.name})`}>{sampleText}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="block">
      <h2 class="block-title"><span class="label-mono">04</span> Letter-spacing</h2>
      <div class="tracking-list">
        {trackingScale.map((t) => (
          <div class="tracking-row">
            <code class="type-token">{t.name}</code>
            <span class="type-px">{t.value}</span>
            <span class="type-usage">{t.usage}</span>
            <p class="tracking-sample" style={`letter-spacing:var(${t.name})`}>STARTING LINE · 47°36N / 122°20W</p>
          </div>
        ))}
      </div>
    </section>

    <section class="block">
      <h2 class="block-title"><span class="label-mono">05</span> Prebuilt classes</h2>

      <div class="prebuilt">
        <code class="prebuilt-name">.label-mono</code>
        <p class="label-mono">starting line · stop 01 / 06 · ride log</p>
      </div>

      <div class="prebuilt">
        <code class="prebuilt-name">.voice-journal</code>
        <p class="voice-journal">"Made it. Thanks for hiking up. If you'd like to chat, sign below."</p>
      </div>
    </section>

    <footer class="page-footer">
      <p class="label-mono">end of design system · 2026</p>
    </footer>
  </main>
</Layout>

<style>
  main {
    max-width: var(--max-width-wide);
    margin: 0 auto;
    padding: var(--space-12) var(--space-4) var(--space-24);
  }

  @media (min-width: 768px) {
    main {
      padding: var(--space-16) var(--space-8) var(--space-24);
    }
  }

  .page-header {
    border-bottom: 1px solid var(--color-border);
    padding-bottom: var(--space-8);
    margin-bottom: var(--space-12);
  }

  .page-title {
    font-size: var(--text-3xl);
    margin-top: var(--space-3);
  }

  .page-sub {
    margin-top: var(--space-4);
    color: var(--color-text-tertiary);
    max-width: var(--max-width-prose);
  }

  .block {
    margin-bottom: var(--space-16);
  }

  .block-title {
    font-size: var(--text-xl);
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-6);
  }

  .block-title .label-mono {
    color: var(--color-accent);
  }

  .block-intro {
    color: var(--color-text-tertiary);
    margin-bottom: var(--space-6);
    max-width: var(--max-width-prose);
  }

  /* Swatch grid */
  .swatch-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  @media (min-width: 600px) {
    .swatch-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1000px) {
    .swatch-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .swatch {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .swatch-fill {
    height: 80px;
    border-bottom: 1px solid var(--color-border);
  }

  .swatch-meta {
    padding: var(--space-3) var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .swatch-name {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-text-primary);
  }

  .swatch-hex {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
  }

  .swatch-note {
    font-size: var(--text-sm);
    color: var(--color-text-tertiary);
    margin-top: var(--space-1);
  }

  /* Semantic alias list */
  .alias-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .alias-row {
    display: grid;
    grid-template-columns: 1fr auto 1fr auto;
    align-items: center;
    gap: var(--space-3);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: var(--space-2) var(--space-4);
  }

  .alias-name, .alias-ref {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-text-primary);
  }

  .alias-arrow {
    color: var(--color-text-tertiary);
    font-family: var(--font-mono);
  }

  .alias-chip {
    width: 24px;
    height: 24px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border);
    justify-self: end;
  }

  /* Type voices */
  .voice-block {
    margin-bottom: var(--space-12);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-6);
    background: var(--color-surface);
  }

  .voice-label {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-6);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--color-border);
  }

  .voice-label code {
    font-family: var(--font-mono);
    color: var(--color-text-primary);
  }

  .type-row {
    display: grid;
    grid-template-columns: auto auto 1fr;
    grid-template-areas:
      "token px usage"
      "sample sample sample";
    align-items: baseline;
    gap: var(--space-2) var(--space-4);
    padding: var(--space-3) 0;
    border-top: 1px dashed var(--color-border);
  }

  .type-row:first-of-type {
    border-top: none;
    padding-top: 0;
  }

  .type-token {
    grid-area: token;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
  }

  .type-px {
    grid-area: px;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
  }

  .type-usage {
    grid-area: usage;
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
  }

  .type-sample {
    grid-area: sample;
    margin: 0;
    line-height: var(--leading-snug);
    color: var(--color-text-primary);
  }

  /* Tracking list */
  .tracking-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .tracking-row {
    display: grid;
    grid-template-columns: auto auto 1fr;
    grid-template-areas:
      "token value usage"
      "sample sample sample";
    align-items: baseline;
    gap: var(--space-2) var(--space-4);
    padding: var(--space-4);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
  }

  .tracking-row .type-token { grid-area: token; }
  .tracking-row .type-px { grid-area: value; }
  .tracking-row .type-usage { grid-area: usage; }

  .tracking-sample {
    grid-area: sample;
    margin: 0;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-primary);
    text-transform: uppercase;
  }

  /* Prebuilt classes */
  .prebuilt {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-6);
    margin-bottom: var(--space-4);
  }

  .prebuilt-name {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
    background: var(--color-surface-inset);
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
    margin-bottom: var(--space-3);
  }

  .prebuilt p {
    margin: 0;
    font-size: var(--text-lg);
  }

  /* Page footer */
  .page-footer {
    margin-top: var(--space-16);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border);
    text-align: center;
  }
</style>
