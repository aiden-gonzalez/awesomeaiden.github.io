---
const cards = [
  {
    period: '2025 · in progress',
    title: 'hydRate',
    description: 'Cross-platform app for finding and rating public water fountains and bathrooms.',
    meta: [
      { label: 'Stack',   value: 'Flutter' },
      { label: 'Backend', value: 'Node · PG' },
    ],
    grade: '+8.4%',
    routeShape: 'climb',
    routeEnd: 'active',
  },
  {
    period: '2022 · completed',
    title: 'Lantern',
    description: 'Accounting MVP giving small business owners digestible financial insights.',
    meta: [
      { label: 'Stack',   value: 'React' },
      { label: 'Backend', value: 'Node · PG' },
    ],
    grade: '+6.1%',
    routeShape: 'climb',
    routeEnd: 'completed',
  },
  {
    period: '2024 · work · Jasper Ridge',
    title: 'Statement engine',
    description: 'Parallelized financial statement generator. 80–90% perf improvement.',
    meta: [
      { label: 'Stack',  value: 'C# .NET' },
      { label: 'Impact', value: '~85%' },
    ],
    grade: '+12.0%',
    routeShape: 'jump',
    routeEnd: 'completed',
  },
  {
    period: '2024 · work · Jasper Ridge',
    title: 'Income allocation engine',
    description: 'Composable engine with operation-tracking framework and AG Grid frontend.',
    meta: [
      { label: 'Stack', value: 'C# · React' },
      { label: 'Scope', value: 'core wf' },
    ],
    grade: '+7.8%',
    routeShape: 'gentle',
    routeEnd: 'completed',
  },
];
---

<section class="ridelog" id="rides">
  <header class="rl-header">
    <p class="label-mono">ride log · projects, by the numbers · 4 rides</p>
    <h2 class="rl-title">Ride log</h2>
    <p class="rl-sub">Selected rides: work projects and personal builds, in the order they shipped (or stopped).</p>
  </header>

  <ul class="rl-grid">
    {cards.map((c) => (
      <li class="card">
        <div class="card-top">
          <p class="card-period label-mono">{c.period}</p>

          <svg
            class={`card-route route-${c.routeShape}`}
            viewBox="0 0 240 80"
            preserveAspectRatio="xMidYMid meet"
            aria-hidden="true"
            role="img"
          >
            {c.routeShape === 'climb' && (
              <polyline class="route-line" points="10,65 50,55 90,42 130,30 170,18 210,12" />
            )}
            {c.routeShape === 'gentle' && (
              <polyline class="route-line" points="10,60 50,55 90,48 130,42 170,34 210,28" />
            )}
            {c.routeShape === 'jump' && (
              <>
                <polyline class="route-line" points="10,60 90,60 105,30 210,28" />
                <polygon class="route-kom" points="100,18 108,30 92,30" />
              </>
            )}
            <circle
              class={`route-end ${c.routeEnd}`}
              cx="210"
              cy={c.routeShape === 'climb' ? 12 : c.routeShape === 'gentle' ? 28 : 28}
              r="5"
            />
          </svg>
        </div>

        <h3 class="card-title">{c.title}</h3>
        <p class="card-desc">{c.description}</p>

        <dl class="card-meta">
          {c.meta.map((m) => (
            <div class="meta-row">
              <dt class="meta-label label-mono">{m.label}</dt>
              <dd class="meta-value">{m.value}</dd>
            </div>
          ))}
          <div class="meta-row meta-grade">
            <dt class="meta-label label-mono">Grade</dt>
            <dd class="meta-value">{c.grade}</dd>
          </div>
        </dl>
      </li>
    ))}
  </ul>
</section>

<style>
  .ridelog {
    background: var(--color-bg);
    padding: var(--space-16) var(--space-4);
  }

  @media (min-width: 768px) {
    .ridelog {
      padding: var(--space-24) var(--space-8);
    }
  }

  .rl-header,
  .rl-grid {
    max-width: var(--max-width-wide);
    margin-left: auto;
    margin-right: auto;
  }

  .rl-title {
    font-size: var(--text-2xl);
    margin-top: var(--space-3);
    color: var(--color-text-primary);
  }

  .rl-sub {
    margin-top: var(--space-3);
    color: var(--color-text-tertiary);
    max-width: var(--max-width-prose);
  }

  .rl-grid {
    list-style: none;
    padding: 0;
    margin: var(--space-12) auto 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  @media (min-width: 800px) {
    .rl-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
  }

  .card-period {
    color: var(--color-text-secondary);
  }

  .card-route {
    width: 120px;
    height: 40px;
    flex-shrink: 0;
  }

  @media (min-width: 480px) {
    .card-route {
      width: 160px;
      height: 50px;
    }
  }

  .route-line {
    fill: none;
    stroke: var(--color-text-secondary);
    stroke-width: 2;
    stroke-linejoin: round;
    stroke-linecap: round;
    vector-effect: non-scaling-stroke;
  }

  .route-kom {
    fill: var(--color-accent);
  }

  .route-end.completed {
    fill: var(--color-text-secondary);
  }

  .route-end.active {
    fill: var(--color-accent);
  }

  .card-title {
    font-size: var(--text-xl);
    color: var(--color-text-primary);
    margin: 0;
  }

  .card-desc {
    color: var(--color-text-primary);
    line-height: var(--leading-normal);
    margin: 0;
  }

  .card-meta {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-3) var(--space-6);
    margin: var(--space-2) 0 0;
    padding-top: var(--space-4);
    border-top: 1px dashed var(--color-border);
  }

  .meta-row {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .meta-label {
    color: var(--color-text-secondary);
  }

  .meta-value {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-text-primary);
    margin: 0;
  }

  .meta-grade .meta-value {
    color: var(--color-accent);
  }
</style>
