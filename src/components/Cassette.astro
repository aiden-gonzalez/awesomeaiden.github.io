---
type Pt = [number, number];

const gears = [
  {
    teeth: 32,
    tag: 'starting line',
    span: 'May 2019',
    title: 'Software engineering intern · Precocity, LLC',
    subtitle: 'Dallas, TX',
    body: 'Patched user-facing bugs in C# and React for a top fintech client. Automated payroll accounting with SQL, Python, and JavaScript for a 90% efficiency gain. Built a GitLab CI/CD pipeline for Kotlin APIs and prototyped a Slack-integrated time tracker in Node.js.',
  },
  {
    teeth: 28,
    tag: 'climb',
    span: 'Jun 2020 – Aug 2021',
    title: 'Software intern · Northrop Grumman',
    subtitle: 'Dulles, VA / Cincinnati, OH',
    body: 'Identified and remediated critical security vulnerabilities in C-based ESPAStar satellite software. Optimized SonarQube API calls to extract 100k+ static analysis findings. Prototyped an internal gig-economy marketplace and presented to the VP of Engineering Innovation.',
  },
  {
    teeth: 25,
    tag: 'waypoint',
    span: 'May 2022',
    title: 'BS Computer Engineering · Purdue',
    subtitle: 'Honors College · Math minor · GPA 3.95, with distinction',
    body: 'Finished Computer Engineering on the Honors-track with distinction. Math minor on the side. West Lafayette, IN.',
  },
  {
    teeth: 21,
    tag: 'waypoint',
    span: 'May 2023',
    title: 'MS Electrical & Computer Engineering · Purdue',
    subtitle: 'Engineering Teaching Assistantship · GPA 3.50',
    body: 'Wrapped the MS in ECE while going deeper on systems. Promoted from intern to full-time consultant at Precocity the same month.',
  },
  {
    teeth: 18,
    tag: 'tempo',
    span: 'Jan 2024 – Dec 2025',
    title: 'Software developer · Jasper Ridge Partners',
    subtitle: 'Fort Worth, TX',
    body: 'Designed a parallelized financial statement generation engine in C# that cut processing time 80–90% for monthly and quarterly reporting. Built ETL pipelines and dbt models integrating Bloomberg market data into analytics. Engineered an auditable income allocation engine in C# .NET with an AG Grid React frontend.',
  },
  {
    teeth: 12,
    tag: 'top gear',
    span: 'Jan 2026 – present',
    title: 'Senior software developer · Jasper Ridge Partners',
    subtitle: 'Technical lead · Seattle (relocating)',
    body: 'Leading junior engineers on code quality, performance, and best practices. Driving production deploys across AWS ECS and Fargate. Relocating to Seattle next.',
  },
];

const activeIdx = 0;
const active = gears[activeIdx];

// SVG geometry, cassette viewBox is square, centred. Largest cog 32T → smallest 12T.
const CX = 220;
const CY = 220;
const HUB_R = 22;

// Map tooth count to outer radius. Spread roughly evenly between MIN and MAX.
const MIN_R = 60;
const MAX_R = 175;
const minTeeth = Math.min(...gears.map((g) => g.teeth));
const maxTeeth = Math.max(...gears.map((g) => g.teeth));
function outerRadius(teeth: number): number {
  return MIN_R + ((teeth - minTeeth) / (maxTeeth - minTeeth)) * (MAX_R - MIN_R);
}

function cogPath(teeth: number, outerR: number, toothDepth = 9): string {
  const innerR = outerR - toothDepth;
  const steps = teeth * 2;
  const offset = -Math.PI / 2; // tooth pointing up so the spider symmetry is intuitive
  const pts: Pt[] = [];
  for (let i = 0; i < steps; i++) {
    const a = offset + (i / steps) * Math.PI * 2;
    const r = i % 2 === 0 ? outerR : innerR;
    pts.push([CX + r * Math.cos(a), CY + r * Math.sin(a)]);
  }
  return 'M ' + pts.map(([x, y]) => `${x.toFixed(1)},${y.toFixed(1)}`).join(' L ') + ' Z';
}

const cogData = gears.map((g, i) => ({
  ...g,
  index: i,
  outerR: outerRadius(g.teeth),
  d: cogPath(g.teeth, outerRadius(g.teeth)),
}));

// Draw order: largest first (z-bottom), smallest last (z-top). Active cog rendered last
// so its accent stroke isn't covered by the smaller cogs that nest inside it.
const drawOrder = [...cogData].sort((a, b) => b.outerR - a.outerR);

// Chain visualization: a real bike chain is a series of figure-eight link plates joined
// by pins. We compute pin positions at uniform arc-length spacing along the chain path
// (so every link is the same length within a single chain), with pitch matched to the cog's
// tooth spacing so the chain visually engages with the cog teeth.
const CHAIN_TAIL = 220;       // CX = 220, so tails reach x = 440 (the right edge of the SVG)
const PLATE_R = 4.5;          // outer radius of each pin hole on the plate (and link half-width)
const WAIST_R = 2.6;          // half-width at the link's pinched waist (gives the "figure 8" look)
const PIN_DOT_R = 1.4;        // radius of the small pin dots at each junction

type ChainGeom = { links: string[]; pins: { x: number; y: number }[] };

// Locate a point at arc-length s along the chain path:
//  1) top tail: from (CX + CHAIN_TAIL, CY - R) leftward to (CX, CY - R)
//  2) half-arc wrapping the LEFT side of the cog from top down to bottom
//  3) bottom tail: from (CX, CY + R) rightward to (CX + CHAIN_TAIL, CY + R)
function pointAtArcLength(s: number, R: number): { x: number; y: number } {
  const arcLen = Math.PI * R;
  if (s <= CHAIN_TAIL) {
    return { x: CX + CHAIN_TAIL - s, y: CY - R };
  }
  if (s <= CHAIN_TAIL + arcLen) {
    const t = (s - CHAIN_TAIL) / R;
    const angle = -Math.PI / 2 - t;
    return { x: CX + R * Math.cos(angle), y: CY + R * Math.sin(angle) };
  }
  return { x: CX + (s - CHAIN_TAIL - arcLen), y: CY + R };
}

// One link plate: a figure-eight outline spanning p1 → p2.  Two 180° arcs around each pin,
// joined by quadratic curves that pinch in at the waist so the link reads as a real chain plate.
function linkPath(
  p1: { x: number; y: number },
  p2: { x: number; y: number }
): string {
  const dx = p2.x - p1.x;
  const dy = p2.y - p1.y;
  const dist = Math.hypot(dx, dy);
  if (dist < 1e-6) return '';
  // Perpendicular unit vector (left of direction of travel in math sense / right on screen)
  const nx = -dy / dist;
  const ny = dx / dist;

  // Endpoints of the perpendicular diameter at each pin
  const p1a = { x: p1.x + nx * PLATE_R, y: p1.y + ny * PLATE_R };
  const p1b = { x: p1.x - nx * PLATE_R, y: p1.y - ny * PLATE_R };
  const p2a = { x: p2.x + nx * PLATE_R, y: p2.y + ny * PLATE_R };
  const p2b = { x: p2.x - nx * PLATE_R, y: p2.y - ny * PLATE_R };

  // Waist control points (one on each side of the midpoint)
  const mx = (p1.x + p2.x) / 2;
  const my = (p1.y + p2.y) / 2;
  const wa = { x: mx + nx * WAIST_R, y: my + ny * WAIST_R };
  const wb = { x: mx - nx * WAIST_R, y: my - ny * WAIST_R };

  const f = (n: number) => n.toFixed(1);
  return [
    `M ${f(p1a.x)},${f(p1a.y)}`,
    `Q ${f(wa.x)},${f(wa.y)} ${f(p2a.x)},${f(p2a.y)}`,
    `A ${PLATE_R} ${PLATE_R} 0 0 1 ${f(p2b.x)},${f(p2b.y)}`,
    `Q ${f(wb.x)},${f(wb.y)} ${f(p1b.x)},${f(p1b.y)}`,
    `A ${PLATE_R} ${PLATE_R} 0 0 1 ${f(p1a.x)},${f(p1a.y)}`,
    'Z',
  ].join(' ');
}

function chainGeometry(R: number, teeth: number): ChainGeom {
  const arcLen = Math.PI * R;
  const totalLen = 2 * CHAIN_TAIL + arcLen;
  // Pitch = the cog's own tooth spacing, so the chain visually engages with the teeth.
  const targetPitch = (2 * Math.PI * R) / teeth;
  const linkCount = Math.max(2, Math.round(totalLen / targetPitch));
  const pitch = totalLen / linkCount;

  const pins = [];
  for (let i = 0; i <= linkCount; i++) {
    pins.push(pointAtArcLength(i * pitch, R));
  }

  const links: string[] = [];
  for (let i = 0; i < pins.length - 1; i++) {
    links.push(linkPath(pins[i], pins[i + 1]));
  }

  return { links, pins };
}

const chainGeoms = gears.map((g) => chainGeometry(outerRadius(g.teeth), g.teeth));
---

<section class="cassette" id="cassette" data-cassette aria-labelledby="cassette-title">
  <div class="cassette-inner">
    <p class="label-mono cassette-label">section 01 · the ride · a timeline · 2019 → 2026</p>

    <div class="cassette-grid">
      <div class="panels">
        {gears.map((g, i) => (
          <article
            class:list={['panel', { active: i === activeIdx }]}
            data-panel-idx={i}
            aria-hidden={i !== activeIdx}
          >
            <p class="panel-eyebrow label-mono">gear {i + 1} / {gears.length} · {g.teeth}T · {g.tag}</p>
            <p class="panel-span label-mono">{g.span}</p>
            {i === activeIdx
              ? <h2 id="cassette-title" class="panel-title">{g.title}</h2>
              : <h2 class="panel-title">{g.title}</h2>
            }
            <p class="panel-subtitle">{g.subtitle}</p>
            <p class="panel-body">{g.body}</p>
          </article>
        ))}
      </div>

      <div class="cog-wrap">
        <svg
          class="cogs"
          viewBox="0 0 440 440"
          role="img"
          aria-labelledby="cassette-svg-title cassette-svg-desc"
        >
          <title id="cassette-svg-title">Bike cassette</title>
          <desc id="cassette-svg-desc">
            Six concentric cogs sharing a hub, ranging from 32 teeth (largest, easy gear) to 12 teeth (smallest, hardest gear). One cog is highlighted in clay red to indicate the active career stage.
          </desc>

          {drawOrder.map((c) => (
            <path
              d={c.d}
              class:list={['cog', { active: c.index === activeIdx }]}
              data-cog-idx={c.index}
            />
          ))}

          {chainGeoms.map((geom, i) => (
            <g
              class:list={['chain', { active: i === activeIdx }]}
              data-chain-idx={i}
              aria-hidden="true"
            >
              {geom.links.map((d) => <path class="chain-link" d={d} />)}
              {geom.pins.map((p) => (
                <circle class="chain-pin" cx={p.x.toFixed(1)} cy={p.y.toFixed(1)} r={PIN_DOT_R} />
              ))}
            </g>
          ))}

          <circle class="hub" cx={CX} cy={CY} r={HUB_R} />
          <circle class="hub-bolt" cx={CX} cy={CY - HUB_R + 5} r="2" />
          <circle class="hub-bolt" cx={CX + (HUB_R - 5) * Math.cos((2 * Math.PI) / 3 - Math.PI / 2)} cy={CY + (HUB_R - 5) * Math.sin((2 * Math.PI) / 3 - Math.PI / 2)} r="2" />
          <circle class="hub-bolt" cx={CX + (HUB_R - 5) * Math.cos((4 * Math.PI) / 3 - Math.PI / 2)} cy={CY + (HUB_R - 5) * Math.sin((4 * Math.PI) / 3 - Math.PI / 2)} r="2" />
        </svg>

        <ol class="gear-legend label-mono" aria-hidden="true">
          {gears.map((g, i) => (
            <li class:list={['legend-tick', { active: i === activeIdx }]} data-tick-idx={i}>
              <span>{String(i + 1).padStart(2, '0')}</span>
              <span>{g.teeth}T</span>
            </li>
          ))}
        </ol>
      </div>
    </div>
  </div>

  <ol class="sr-only" aria-label="Career timeline by gear">
    {gears.map((g) => (
      <li>
        <strong>{g.span}</strong>, {g.title}. {g.subtitle}. {g.body}
      </li>
    ))}
  </ol>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initCassette() {
    const section = document.querySelector<HTMLElement>('[data-cassette]');
    if (!section) return;

    // Default state is the no-JS / reduced-motion timeline (every panel visible inline).
    // Only opt into the carousel + pinned-scroll mechanic when JS is available and the
    // user hasn't asked for reduced motion.
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reducedMotion) return;
    section.classList.add('js-active');

    const panels = Array.from(section.querySelectorAll<HTMLElement>('[data-panel-idx]'));
    const cogs = Array.from(section.querySelectorAll<SVGPathElement>('[data-cog-idx]'));
    const ticks = Array.from(section.querySelectorAll<HTMLElement>('[data-tick-idx]'));
    const chains = Array.from(section.querySelectorAll<SVGGElement>('[data-chain-idx]'));
    const total = panels.length;
    if (total === 0) return;

    // Map cogs, ticks, and chains by their data-idx so the visual draw order doesn't matter.
    const cogByIdx = new Map<number, SVGPathElement>();
    cogs.forEach((c) => {
      const i = Number(c.dataset.cogIdx);
      if (!Number.isNaN(i)) cogByIdx.set(i, c);
    });
    const tickByIdx = new Map<number, HTMLElement>();
    ticks.forEach((t) => {
      const i = Number(t.dataset.tickIdx);
      if (!Number.isNaN(i)) tickByIdx.set(i, t);
    });
    const chainByIdx = new Map<number, SVGGElement>();
    chains.forEach((c) => {
      const i = Number(c.dataset.chainIdx);
      if (!Number.isNaN(i)) chainByIdx.set(i, c);
    });

    let currentIdx = 0;
    const setActive = (idx: number) => {
      if (idx === currentIdx) return;
      panels[currentIdx]?.classList.remove('active');
      panels[currentIdx]?.setAttribute('aria-hidden', 'true');
      panels[idx]?.classList.add('active');
      panels[idx]?.setAttribute('aria-hidden', 'false');
      cogByIdx.get(currentIdx)?.classList.remove('active');
      cogByIdx.get(idx)?.classList.add('active');
      tickByIdx.get(currentIdx)?.classList.remove('active');
      tickByIdx.get(idx)?.classList.add('active');
      chainByIdx.get(currentIdx)?.classList.remove('active');
      chainByIdx.get(idx)?.classList.add('active');
      currentIdx = idx;
    };

    // Scroll length: ~60vh of scroll per gear shift (tighter than 100vh).
    const SCROLL_PER_GEAR = 60;
    ScrollTrigger.create({
      trigger: section,
      start: 'top top',
      end: `+=${total * SCROLL_PER_GEAR}%`,
      pin: '.cassette-inner',
      pinSpacing: true,
      onUpdate: (self) => {
        const idx = Math.min(total - 1, Math.floor(self.progress * total));
        setActive(idx);
      },
    });
  }

  if (document.readyState === 'complete') {
    initCassette();
  } else {
    window.addEventListener('load', initCassette);
  }
</script>

<style>
  .cassette {
    position: relative;
    background: var(--color-bg);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  /* The inner container is what GSAP pins. It fills the viewport while pinned, so the
     cassette and panel stay centred regardless of where the user is in the scroll range. */
  .cassette-inner {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: var(--space-6) var(--space-4);
    box-sizing: border-box;
  }

  @media (min-width: 768px) {
    .cassette-inner {
      padding: var(--space-12) var(--space-8);
    }
  }

  .cassette-label,
  .cassette-grid {
    max-width: var(--max-width-wide);
    margin-left: auto;
    margin-right: auto;
    width: 100%;
  }

  .cassette-label {
    color: var(--color-text-secondary);
    margin-bottom: var(--space-4);
  }

  @media (min-width: 900px) {
    .cassette-label {
      margin-bottom: var(--space-8);
    }
  }

  .cassette-grid {
    display: grid;
    grid-template-columns: 1fr;
    grid-template-areas:
      "cogs"
      "panels";
    gap: var(--space-6);
    align-items: center;
  }

  @media (min-width: 900px) {
    .cassette-grid {
      grid-template-columns: minmax(0, 1.1fr) minmax(0, 1fr);
      grid-template-areas: "panels cogs";
      gap: var(--space-16);
    }
  }

  .panels { grid-area: panels; }
  .cog-wrap { grid-area: cogs; }

  /* Default: every panel renders inline as a vertical timeline.  This is what no-JS users
     and reduced-motion users see.  The carousel below is enabled only when JS is active. */
  .panels {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .panel {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    max-width: var(--max-width-prose);
    padding-bottom: var(--space-6);
    border-bottom: 1px dashed var(--color-border);
  }

  .panel:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  /* Carousel mode: only the active panel is visible, stacked in a single grid cell.  Enabled
     by the cassette script when JS is available and the user hasn't requested reduced motion. */
  .cassette.js-active .panels {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
  }

  .cassette.js-active .panel {
    grid-area: 1 / 1;
    padding-bottom: 0;
    border-bottom: none;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity var(--duration-fast) var(--ease-out-quart);
  }

  .cassette.js-active .panel.active {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  .panel-eyebrow {
    color: var(--color-accent);
  }

  .panel-span {
    color: var(--color-text-secondary);
  }

  .panel-title {
    /* Fluid sizing: smaller on narrow viewports so the title fits on one line. */
    font-size: clamp(var(--text-lg), 4.5vw, var(--text-2xl));
    margin: var(--space-2) 0 0;
    color: var(--color-text-primary);
    line-height: var(--leading-snug);
  }

  .panel-subtitle {
    margin: 0;
    color: var(--color-text-secondary);
    font-size: var(--text-base);
  }

  .panel-body {
    margin: var(--space-3) 0 0;
    color: var(--color-text-primary);
    line-height: var(--leading-normal);
  }

  /* Cog SVG */
  .cog-wrap {
    position: relative;
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: var(--space-6);
  }

  .cogs {
    width: 100%;
    max-width: 440px;
    height: auto;
    display: block;
  }

  .cog {
    fill: none;
    stroke: var(--color-forest-soft);
    stroke-width: 1.25;
    stroke-linejoin: round;
    vector-effect: non-scaling-stroke;
  }

  /* Active cog highlight only takes effect in the JS-driven carousel.  Without JS we'd
     have one cog flagged active at server-render time but there's no active gear concept. */
  .cassette.js-active .cog.active {
    stroke: var(--color-accent);
    stroke-width: 1.75;
  }

  .chain {
    display: none;
  }

  .cassette.js-active .chain.active {
    display: inline;
  }

  .chain-link {
    fill: var(--color-bg);
    stroke: var(--color-text-secondary);
    stroke-width: 1.25;
    stroke-linejoin: round;
    vector-effect: non-scaling-stroke;
  }

  .chain-pin {
    fill: var(--color-text-secondary);
  }

  .hub {
    fill: var(--color-bg);
    stroke: var(--color-text-secondary);
    stroke-width: 1.25;
    vector-effect: non-scaling-stroke;
  }

  .hub-bolt {
    fill: var(--color-text-secondary);
  }

  /* Tick legend along the side of the cassette */
  .gear-legend {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    text-align: right;
  }

  .legend-tick {
    display: flex;
    flex-direction: column;
    gap: 2px;
    color: var(--color-text-tertiary);
    line-height: 1.1;
  }

  .cassette.js-active .legend-tick.active {
    color: var(--color-accent);
  }

  .legend-tick span:first-child {
    font-size: var(--text-xs);
  }

  .legend-tick span:last-child {
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-loose);
  }

  /* Below the tablet breakpoint: shrink the cassette so the panel below still gets room,
     and re-flow the gear legend as a horizontal row of ticks under the cog instead of a
     vertical column beside it.  This block goes last so it overrides the base rules above. */
  @media (max-width: 900px) {
    .cog-wrap {
      grid-template-columns: 1fr;
      justify-items: center;
      gap: var(--space-4);
    }
    .cogs {
      width: 60%;
      max-width: 280px;
    }
    .gear-legend {
      flex-direction: row;
      justify-content: space-between;
      width: 100%;
      max-width: 280px;
      text-align: center;
      gap: var(--space-3);
    }
    .legend-tick {
      align-items: center;
    }
  }
</style>
