---
import projects from '../data/projects.json';
import { projectShapes, PROJECT_SHAPE_VIEW } from '../lib/project-shapes';

type GalleryItem =
  | { kind: 'image'; src: string; alt: string }
  | { kind: 'doc'; src: string; label: string };

type ProjectDetail = {
  body?: string[];
  gallery?: GalleryItem[];
  links?: { label: string; href: string }[];
};

type Project = {
  title: string;
  period: string;
  org?: string;
  description: string;
  stack: string[];
  link?: string;
  status: 'active' | 'completed';
  shape: keyof typeof projectShapes;
  detail?: ProjectDetail;
};

const cards = projects as Project[];

for (const c of cards) {
  if (c.link && c.detail) {
    throw new Error(
      `Project "${c.title}" has both \`link\` and \`detail\`. Use \`detail.links\` for in-panel links; drop the top-level \`link\`.`,
    );
  }
}

const slugify = (s: string) =>
  s.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
---

<section class="projects" id="projects">
  <header class="projects-header">
    <p class="label-mono">selected work · 2020 → present</p>
  </header>

  <ul class="projects-grid">
    {cards.map((c) => {
      const shape = projectShapes[c.shape] ?? projectShapes.series;
      const isExpandable = !!c.detail;
      const hasLink = !!c.link;
      const slug = slugify(c.title);
      const detailId = `detail-${slug}`;

      const summary = (
        <>
          <div class="card-top">
            <div class="card-meta">
              <p class="card-period label-mono">
                {c.period}{c.org ? ` · ${c.org}` : ''}
              </p>
              {c.status === 'active' && (
                <>
                  <span class="card-active-dot" aria-hidden="true"></span>
                  <p class="card-active label-mono">active</p>
                </>
              )}
              {isExpandable && (
                <span class="card-toggle-icon label-mono" aria-hidden="true">▾</span>
              )}
            </div>
            <svg
              class="card-map"
              viewBox={`0 0 ${PROJECT_SHAPE_VIEW.width} ${PROJECT_SHAPE_VIEW.height}`}
              preserveAspectRatio="xMidYMid meet"
              aria-hidden="true"
              role="img"
            >
              <path class="map-line" d={shape.path} fill="none" />
              {shape.dots.map((d) => (
                <circle class="map-dot" cx={d.x} cy={d.y} r="3" />
              ))}
            </svg>
          </div>
          <h3 class="card-title">{c.title}</h3>
          <p class="card-desc">{c.description}</p>
          <ul class="card-stack">
            {c.stack.map((s) => <li class="stack-tag label-mono">{s}</li>)}
          </ul>
        </>
      );

      if (isExpandable) {
        return (
          <>
            <li class="reveal">
              <button
                class="card card-expandable"
                type="button"
                aria-expanded="false"
                aria-controls={detailId}
              >
                {summary}
              </button>
            </li>
            <li class="detail-row" id={detailId} hidden>
              <div class="detail-inner">
                {c.detail!.body && c.detail!.body.length > 0 && (
                  <div class="detail-body">
                    {c.detail!.body.map((p) => <p>{p}</p>)}
                  </div>
                )}
                {c.detail!.gallery && c.detail!.gallery.length > 0 && (
                  <div class="detail-gallery">
                    {c.detail!.gallery.map((item) => (
                      item.kind === 'image' ? (
                        <a
                          class="gallery-item gallery-image"
                          href={item.src}
                          target="_blank"
                          rel="noopener noreferrer"
                        >
                          <img src={item.src} alt={item.alt} loading="lazy" />
                        </a>
                      ) : (
                        <a
                          class="gallery-item gallery-doc"
                          href={item.src}
                          target="_blank"
                          rel="noopener noreferrer"
                        >
                          <span class="doc-icon label-mono" aria-hidden="true">PDF</span>
                          <span class="doc-label">{item.label}</span>
                        </a>
                      )
                    ))}
                  </div>
                )}
                {c.detail!.links && c.detail!.links.length > 0 && (
                  <ul class="detail-links label-mono">
                    {c.detail!.links.map((l) => (
                      <li>
                        <a href={l.href} target="_blank" rel="noopener noreferrer">{l.label} ↗</a>
                      </li>
                    ))}
                  </ul>
                )}
              </div>
            </li>
          </>
        );
      }

      if (hasLink) {
        return (
          <li class="reveal">
            <a
              class="card"
              href={c.link}
              target="_blank"
              rel="noopener noreferrer"
            >
              {summary}
            </a>
          </li>
        );
      }

      return (
        <li class="reveal">
          <article class="card">
            {summary}
          </article>
        </li>
      );
    })}
  </ul>
</section>

<script>
  const revealCards = document.querySelectorAll('#projects .reveal');
  const revealObserver = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-revealed');
          revealObserver.unobserve(entry.target);
        }
      }
    },
    { threshold: 0.5 }
  );
  for (const card of revealCards) revealObserver.observe(card);

  const triggers = document.querySelectorAll<HTMLButtonElement>('#projects .card-expandable');
  let openTrigger: HTMLButtonElement | null = null;

  const rowFor = (trigger: HTMLButtonElement) => {
    const id = trigger.getAttribute('aria-controls');
    return id ? document.getElementById(id) : null;
  };

  const positionNotch = (trigger: HTMLButtonElement, row: HTMLElement) => {
    const triggerRect = trigger.getBoundingClientRect();
    const rowRect = row.getBoundingClientRect();
    const x = triggerRect.left + triggerRect.width / 2 - rowRect.left;
    row.style.setProperty('--notch-x', `${x}px`);
  };

  const closeTrigger = (trigger: HTMLButtonElement) => {
    trigger.setAttribute('aria-expanded', 'false');
    rowFor(trigger)?.setAttribute('hidden', '');
  };

  const openTriggerFn = (trigger: HTMLButtonElement) => {
    trigger.setAttribute('aria-expanded', 'true');
    const row = rowFor(trigger);
    if (!row) return;
    row.removeAttribute('hidden');
    positionNotch(trigger, row);
  };

  for (const trigger of triggers) {
    trigger.addEventListener('click', () => {
      if (openTrigger === trigger) {
        closeTrigger(trigger);
        openTrigger = null;
      } else {
        if (openTrigger) closeTrigger(openTrigger);
        openTriggerFn(trigger);
        openTrigger = trigger;
      }
    });
  }

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && openTrigger) {
      closeTrigger(openTrigger);
      openTrigger = null;
    }
  });

  window.addEventListener('resize', () => {
    if (!openTrigger) return;
    const row = rowFor(openTrigger);
    if (row) positionNotch(openTrigger, row);
  });
</script>

<style>
  .projects {
    background: var(--color-bg);
    padding: var(--space-16) var(--space-4);
  }

  @media (min-width: 768px) {
    .projects {
      padding: var(--space-24) var(--space-8);
    }
  }

  .projects-header,
  .projects-grid {
    max-width: var(--max-width-wide);
    margin-left: auto;
    margin-right: auto;
  }

  .projects-header p {
    color: var(--color-text-secondary);
    margin: 0;
  }

  .projects-grid {
    list-style: none;
    padding: 0;
    margin: var(--space-12) auto 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  @media (min-width: 800px) {
    .projects-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .projects-grid > li {
    display: flex;
  }

  /* Card */
  .card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    width: 100%;
    color: inherit;
    text-decoration: none;
    transition: border-color var(--duration-fast) var(--ease-out-quart),
                transform var(--duration-fast) var(--ease-out-quart);
  }

  /* The expandable card is itself a button — reset button defaults. */
  .card-expandable {
    font: inherit;
    text-align: inherit;
    cursor: pointer;
  }

  a.card:hover,
  a.card:focus-visible,
  .card-expandable:hover,
  .card-expandable:focus-visible {
    border-color: var(--color-accent);
    transform: translateY(-2px);
  }

  .card-expandable:focus-visible {
    outline: none;
  }

  .card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
  }

  .card-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
    margin: 0;
  }

  .card-meta > p {
    margin: 0;
  }

  .card-period {
    color: var(--color-text-secondary);
  }

  .card-active {
    color: var(--color-accent);
  }

  .card-active-dot {
    width: 0.4em;
    height: 0.4em;
    border-radius: 50%;
    background: var(--color-accent);
    flex-shrink: 0;
    transform: translateY(-0.75px);
  }

  .card-toggle-icon {
    color: var(--color-text-secondary);
    margin-left: var(--space-1);
    transition: transform var(--duration-fast) var(--ease-out-quart);
    display: inline-block;
  }

  .card-expandable[aria-expanded="true"] .card-toggle-icon {
    transform: rotate(180deg);
  }

  .card-map {
    width: 120px;
    height: 40px;
    flex-shrink: 0;
  }

  @media (min-width: 480px) {
    .card-map {
      width: 160px;
      height: 54px;
    }
  }

  .map-line {
    stroke: var(--color-text-secondary);
    stroke-width: 1.75;
    stroke-linejoin: round;
    stroke-linecap: round;
    vector-effect: non-scaling-stroke;
  }

  .map-dot {
    fill: var(--color-text-secondary);
  }

  /* Card text */
  .card-title {
    font-size: var(--text-xl);
    color: var(--color-text-primary);
    margin: 0;
  }

  .card-desc {
    color: var(--color-text-primary);
    line-height: var(--leading-normal);
    margin: 0;
  }

  /* Stack tags */
  .card-stack {
    list-style: none;
    padding: var(--space-4) 0 0;
    margin: var(--space-2) 0 0;
    border-top: 1px dashed var(--color-border);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-3);
  }

  .stack-tag {
    color: var(--color-text-secondary);
  }

  .stack-tag:not(:last-child)::after {
    content: ' ·';
    color: var(--color-text-tertiary);
  }

  /* Detail row — sibling of the card, spans full grid width when shown.
     The ::before is a small rotated-square notch on the top edge that
     points up at the originating card. Its x position is set in JS via
     `--notch-x` whenever the panel is opened or the window is resized. */
  .detail-row {
    grid-column: 1 / -1;
    list-style: none;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-6);
    position: relative;
  }

  .detail-row[hidden] {
    display: none;
  }

  .detail-row::before {
    content: '';
    position: absolute;
    top: -7px;
    left: var(--notch-x, 50%);
    width: 12px;
    height: 12px;
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
    border-left: 1px solid var(--color-border);
    transform: translateX(-50%) rotate(45deg);
  }

  .detail-inner > * + * {
    margin-top: var(--space-6);
  }

  .detail-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .detail-body p {
    margin: 0;
    line-height: var(--leading-relaxed);
    color: var(--color-text-primary);
  }

  .detail-gallery {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: var(--space-3);
  }

  .gallery-item {
    display: block;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    overflow: hidden;
    aspect-ratio: 4 / 3;
    background: var(--color-surface-inset);
    text-decoration: none;
    color: inherit;
    transition: border-color var(--duration-fast) var(--ease-out-quart),
                transform var(--duration-fast) var(--ease-out-quart);
  }

  .gallery-item:hover,
  .gallery-item:focus-visible {
    border-color: var(--color-accent);
    transform: translateY(-1px);
  }

  .gallery-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .gallery-doc {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    padding: var(--space-3);
    text-align: center;
  }

  .doc-icon {
    background: var(--color-accent);
    color: var(--color-bone);
    padding: 0.15em 0.5em;
    border-radius: var(--radius-sm);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-loose);
  }

  .doc-label {
    color: var(--color-text-primary);
    font-size: var(--text-sm);
  }

  .detail-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3) var(--space-6);
  }

  .detail-links a {
    color: var(--color-accent);
    text-decoration: none;
    border-bottom: 1px dashed var(--color-accent);
  }

  .detail-links a:hover,
  .detail-links a:focus-visible {
    color: var(--color-text-primary);
    border-bottom-color: var(--color-text-primary);
  }
</style>
