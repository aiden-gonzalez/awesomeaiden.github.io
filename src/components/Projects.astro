---
import projects from '../data/projects.json';
import { projectShapes, PROJECT_SHAPE_VIEW } from '../lib/project-shapes';

type GalleryItem =
  | { kind: 'image'; src: string; alt: string }
  | { kind: 'doc'; src: string; label: string }
  | { kind: 'video'; src: string; label: string };

// Parse a YouTube URL into a video ID, or null for unsupported/non-YouTube URLs.
// Drives thumbnail rendering: if we get an ID we use the i.ytimg.com poster;
// otherwise the video tile falls back to a badge-only style like the PDF tile.
function getYouTubeId(url: string): string | null {
  try {
    const u = new URL(url);
    if (u.hostname === 'youtu.be') {
      return u.pathname.slice(1).split('/')[0] || null;
    }
    if (u.hostname.endsWith('youtube.com') || u.hostname.endsWith('youtube-nocookie.com')) {
      const v = u.searchParams.get('v');
      if (v) return v;
      const parts = u.pathname.split('/').filter(Boolean);
      if (parts[0] === 'embed' || parts[0] === 'shorts') return parts[1] || null;
    }
  } catch {
    return null;
  }
  return null;
}

type ProjectDetail = {
  body?: string[];
  gallery?: GalleryItem[];
  links?: { label: string; href: string }[];
};

type Project = {
  title: string;
  period: string;
  org?: string;
  description: string;
  stack: string[];
  link?: string;
  status: 'active' | 'completed';
  shape: keyof typeof projectShapes;
  detail?: ProjectDetail;
};

const cards = projects as Project[];

for (const c of cards) {
  if (c.link && c.detail) {
    throw new Error(
      `Project "${c.title}" has both \`link\` and \`detail\`. Use \`detail.links\` for in-panel links; drop the top-level \`link\`.`,
    );
  }
}

const slugify = (s: string) =>
  s.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
---

<section class="projects" id="projects">
  <header class="projects-header">
    <p class="label-mono">selected work · click a card to expand</p>
  </header>

  <ul class="projects-grid">
    {cards.map((c) => {
      const shape = projectShapes[c.shape] ?? projectShapes.series;
      const isExpandable = !!c.detail;
      const hasLink = !!c.link;
      const slug = slugify(c.title);
      const detailId = `detail-${slug}`;

      const summary = (
        <>
          <div class="card-top">
            <div class="card-meta">
              <p class="card-period label-mono">
                {c.period}{c.org ? ` · ${c.org}` : ''}
              </p>
              {c.status === 'active' && (
                <>
                  <span class="card-active-dot" aria-hidden="true"></span>
                  <p class="card-active label-mono">active</p>
                </>
              )}
            </div>
            <svg
              class="card-map"
              viewBox={`0 0 ${PROJECT_SHAPE_VIEW.width} ${PROJECT_SHAPE_VIEW.height}`}
              preserveAspectRatio="xMidYMid meet"
              aria-hidden="true"
              role="img"
            >
              <path class="map-line" d={shape.path} fill="none" />
              {shape.dots.map((d) => (
                <circle class="map-dot" cx={d.x} cy={d.y} r="3" />
              ))}
            </svg>
          </div>
          <h3 class="card-title">{c.title}</h3>
          <p class="card-desc">{c.description}</p>
          <div class="card-footer">
            <ul class="card-stack">
              {c.stack.map((s) => <li class="stack-tag label-mono">{s}</li>)}
            </ul>
            {isExpandable && (
              <span class="card-toggle-icon label-mono" aria-hidden="true">▾</span>
            )}
            {hasLink && (
              <span class="card-link-icon label-mono" aria-hidden="true">↗</span>
            )}
          </div>
        </>
      );

      if (isExpandable) {
        return (
          <>
            <li class="reveal">
              <button
                class="card card-expandable"
                type="button"
                aria-expanded="false"
                aria-controls={detailId}
              >
                {summary}
              </button>
            </li>
            <li class="detail-row" id={detailId} hidden>
              <div class="detail-inner">
                {(c.detail!.body && c.detail!.body.length > 0) || (c.detail!.links && c.detail!.links.length > 0) ? (
                  <div class="detail-primary">
                    {c.detail!.body && c.detail!.body.length > 0 && (
                      <section class="detail-section">
                        <h4 class="detail-label label-mono">notes</h4>
                        <div class="detail-body">
                          {c.detail!.body.map((p) => <p>{p}</p>)}
                        </div>
                      </section>
                    )}
                    {c.detail!.links && c.detail!.links.length > 0 && (
                      <section class="detail-section">
                        <h4 class="detail-label label-mono">elsewhere</h4>
                        <ul class="detail-links label-mono">
                          {c.detail!.links.map((l) => (
                            <li>
                              <a href={l.href} target="_blank" rel="noopener noreferrer">{l.label} ↗</a>
                            </li>
                          ))}
                        </ul>
                      </section>
                    )}
                  </div>
                ) : null}
                {c.detail!.gallery && c.detail!.gallery.length > 0 && (
                  <section class="detail-section detail-aside">
                    <h4 class="detail-label label-mono">gallery</h4>
                    <div class="gallery-wrapper">
                      <div class="detail-gallery">
                        {c.detail!.gallery.map((item) => {
                          if (item.kind === 'image') {
                            return (
                              <a
                                class="gallery-item gallery-image"
                                href={item.src}
                                target="_blank"
                                rel="noopener noreferrer"
                              >
                                <img src={item.src} alt={item.alt} loading="lazy" />
                              </a>
                            );
                          }
                          if (item.kind === 'video') {
                            const ytId = getYouTubeId(item.src);
                            const poster = ytId ? `https://i.ytimg.com/vi/${ytId}/mqdefault.jpg` : null;
                            return (
                              <a
                                class:list={['gallery-item', 'gallery-video', { 'has-thumb': !!poster }]}
                                href={item.src}
                                target="_blank"
                                rel="noopener noreferrer"
                              >
                                {poster && (
                                  <img class="video-thumb" src={poster} alt="" loading="lazy" aria-hidden="true" />
                                )}
                                <span class="video-play" aria-hidden="true">▶</span>
                                <span class="video-label">{item.label}</span>
                              </a>
                            );
                          }
                          return (
                            <a
                              class="gallery-item gallery-doc"
                              href={item.src}
                              target="_blank"
                              rel="noopener noreferrer"
                            >
                              <span class="doc-icon label-mono" aria-hidden="true">PDF</span>
                              <span class="doc-label">{item.label}</span>
                            </a>
                          );
                        })}
                      </div>
                      <button class="gallery-nav gallery-nav-prev" type="button" aria-label="Previous">←</button>
                      <button class="gallery-nav gallery-nav-next" type="button" aria-label="Next">→</button>
                    </div>
                  </section>
                )}
              </div>
            </li>
          </>
        );
      }

      if (hasLink) {
        return (
          <li class="reveal">
            <a
              class="card"
              href={c.link}
              target="_blank"
              rel="noopener noreferrer"
            >
              {summary}
            </a>
          </li>
        );
      }

      return (
        <li class="reveal">
          <article class="card">
            {summary}
          </article>
        </li>
      );
    })}
  </ul>
</section>

<script>
  const revealCards = document.querySelectorAll('#projects .reveal');
  const revealObserver = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-revealed');
          revealObserver.unobserve(entry.target);
        }
      }
    },
    { threshold: 0.5 }
  );
  for (const card of revealCards) revealObserver.observe(card);

  const triggers = document.querySelectorAll<HTMLButtonElement>('#projects .card-expandable');
  let openTrigger: HTMLButtonElement | null = null;

  const rowFor = (trigger: HTMLButtonElement) => {
    const id = trigger.getAttribute('aria-controls');
    return id ? document.getElementById(id) : null;
  };

  const positionNotch = (trigger: HTMLButtonElement, row: HTMLElement) => {
    const triggerRect = trigger.getBoundingClientRect();
    const rowRect = row.getBoundingClientRect();
    const x = triggerRect.left + triggerRect.width / 2 - rowRect.left;
    row.style.setProperty('--notch-x', `${x}px`);
  };

  const closeTrigger = (trigger: HTMLButtonElement) => {
    trigger.setAttribute('aria-expanded', 'false');
    rowFor(trigger)?.setAttribute('hidden', '');
  };

  const openTriggerFn = (trigger: HTMLButtonElement) => {
    trigger.setAttribute('aria-expanded', 'true');
    const row = rowFor(trigger);
    if (!row) return;
    row.removeAttribute('hidden');
    positionNotch(trigger, row);
  };

  for (const trigger of triggers) {
    trigger.addEventListener('click', () => {
      if (openTrigger === trigger) {
        closeTrigger(trigger);
        openTrigger = null;
      } else {
        if (openTrigger) closeTrigger(openTrigger);
        openTriggerFn(trigger);
        openTrigger = trigger;
      }
    });
  }

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && openTrigger) {
      closeTrigger(openTrigger);
      openTrigger = null;
    }
  });

  window.addEventListener('resize', () => {
    if (!openTrigger) return;
    const row = rowFor(openTrigger);
    if (row) positionNotch(openTrigger, row);
  });

  for (const wrapper of document.querySelectorAll<HTMLElement>('#projects .gallery-wrapper')) {
    const gallery = wrapper.querySelector<HTMLElement>('.detail-gallery');
    const prev = wrapper.querySelector<HTMLButtonElement>('.gallery-nav-prev');
    const next = wrapper.querySelector<HTMLButtonElement>('.gallery-nav-next');
    if (!gallery || !prev || !next) continue;

    const scrollByItem = (direction: 1 | -1) => {
      const items = Array.from(gallery.querySelectorAll<HTMLElement>('.gallery-item'));
      if (items.length === 0) return;
      const galleryLeft = gallery.getBoundingClientRect().left;

      let currentIndex = 0;
      let minOffset = Infinity;
      items.forEach((item, i) => {
        const offset = item.getBoundingClientRect().left - galleryLeft;
        if (offset >= -2 && offset < minOffset) {
          minOffset = offset;
          currentIndex = i;
        }
      });

      const target = items[Math.max(0, Math.min(items.length - 1, currentIndex + direction))];
      target?.scrollIntoView({ behavior: 'smooth', inline: 'start', block: 'nearest' });
    };

    prev.addEventListener('click', () => scrollByItem(-1));
    next.addEventListener('click', () => scrollByItem(1));
  }
</script>

<style>
  .projects {
    background: var(--color-bg);
    padding: var(--space-16) var(--space-4);
  }

  @media (min-width: 768px) {
    .projects {
      padding: var(--space-24) var(--space-8);
    }
  }

  .projects-header,
  .projects-grid {
    max-width: var(--max-width-wide);
    margin-left: auto;
    margin-right: auto;
  }

  .projects-header p {
    color: var(--color-text-secondary);
    margin: 0;
  }

  .projects-grid {
    list-style: none;
    padding: 0;
    margin: var(--space-12) auto 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    /* dense packing lets a right-column card backfill the row when the
       left-column card above it is expanded and its detail-row spans
       the full width. Without this, the right card would drop below
       the detail panel because items normally flow in DOM order. */
    grid-auto-flow: dense;
  }

  @media (min-width: 800px) {
    .projects-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .projects-grid > li {
    display: flex;
  }

  /* Card */
  .card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    width: 100%;
    color: inherit;
    text-decoration: none;
    transition: border-color var(--duration-fast) var(--ease-out-quart),
                transform var(--duration-fast) var(--ease-out-quart);
  }

  /* The expandable card is itself a button — reset button defaults. */
  .card-expandable {
    font: inherit;
    text-align: inherit;
    cursor: pointer;
  }

  a.card:hover,
  a.card:focus-visible,
  .card-expandable:hover,
  .card-expandable:focus-visible {
    border-color: var(--color-accent);
    transform: translateY(-2px);
  }

  .card-expandable:focus-visible {
    outline: none;
  }

  .card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
  }

  .card-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
    margin: 0;
  }

  .card-meta > p {
    margin: 0;
  }

  .card-period {
    color: var(--color-text-secondary);
  }

  .card-active {
    color: var(--color-accent);
  }

  .card-active-dot {
    width: 0.4em;
    height: 0.4em;
    border-radius: 50%;
    background: var(--color-accent);
    flex-shrink: 0;
    transform: translateY(-0.75px);
  }

  .card-toggle-icon,
  .card-link-icon {
    color: var(--color-text-secondary);
    transition: transform var(--duration-fast) var(--ease-out-quart);
    display: inline-block;
    line-height: 1;
    font-size: var(--text-lg);
  }

  .card-expandable[aria-expanded="true"] .card-toggle-icon {
    transform: rotate(180deg);
  }

  a.card:hover .card-link-icon,
  a.card:focus-visible .card-link-icon {
    color: var(--color-accent);
    transform: translate(1px, -1px);
  }

  .card-map {
    width: 120px;
    height: 40px;
    flex-shrink: 0;
  }

  @media (min-width: 480px) {
    .card-map {
      width: 160px;
      height: 54px;
    }
  }

  .map-line {
    stroke: var(--color-text-secondary);
    stroke-width: 1.75;
    stroke-linejoin: round;
    stroke-linecap: round;
    vector-effect: non-scaling-stroke;
  }

  .map-dot {
    fill: var(--color-text-secondary);
  }

  /* Card text */
  .card-title {
    font-size: var(--text-xl);
    color: var(--color-text-primary);
    margin: 0;
  }

  .card-desc {
    color: var(--color-text-primary);
    line-height: var(--leading-normal);
    margin: 0;
  }

  /* Footer row holds stack tags on the left and the expand chevron on
     the right. Owns the dashed top border that previously lived on the
     stack list. */
  .card-footer {
    margin: auto 0 0;
    padding: var(--space-4) 0 0;
    border-top: 1px dashed var(--color-border);
    display: flex;
    align-items: flex-end;
    gap: var(--space-3);
  }

  /* Stack tags */
  .card-stack {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-3);
    flex: 1;
  }

  .stack-tag {
    color: var(--color-text-secondary);
  }

  .stack-tag:not(:last-child)::after {
    content: ' ·';
    color: var(--color-text-tertiary);
  }

  /* Detail row — sibling of the card, spans full grid width when shown.
     The ::before is a small rotated-square notch on the top edge that
     points up at the originating card. Its x position is set in JS via
     `--notch-x` whenever the panel is opened or the window is resized. */
  .detail-row {
    grid-column: 1 / -1;
    list-style: none;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-6);
    position: relative;
  }

  .detail-row[hidden] {
    display: none;
  }

  .detail-row::before {
    content: '';
    position: absolute;
    top: -7px;
    left: var(--notch-x, 50%);
    width: 12px;
    height: 12px;
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
    border-left: 1px solid var(--color-border);
    transform: translateX(-50%) rotate(45deg);
  }

  .detail-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  /* Two-column 3:1 layout on desktop when both primary content and an
     aside gallery are present. min-width: 0 on the children prevents the
     gallery's flex row from growing the aside past its 1fr track. */
  @media (min-width: 800px) {
    .detail-inner:has(.detail-primary):has(.detail-aside) {
      grid-template-columns: 2fr 1fr;
      gap: var(--space-8);
      align-items: start;
    }
  }

  .detail-primary,
  .detail-aside {
    min-width: 0;
  }

  .detail-primary > .detail-section + .detail-section {
    margin-top: var(--space-6);
    padding-top: var(--space-6);
    border-top: 1px dashed var(--color-border);
  }

  .detail-label {
    color: var(--color-text-secondary);
    margin: 0 0 var(--space-4);
    font-weight: inherit;
  }

  .detail-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .detail-body p {
    margin: 0;
    line-height: var(--leading-relaxed);
    color: var(--color-text-primary);
  }

  /* Gallery: horizontal scroll-snap carousel. Items have fixed height; each
     tile's width follows its own aspect-ratio. Prev/next buttons inside
     .gallery-wrapper appear on hover and use scrollIntoView to advance. */
  .gallery-wrapper {
    position: relative;
  }

  .detail-gallery {
    display: flex;
    gap: var(--space-3);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    scrollbar-width: none;
    padding: 2px 0;
  }

  .detail-gallery::-webkit-scrollbar {
    display: none;
  }

  .gallery-item {
    display: block;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    overflow: hidden;
    background: var(--color-surface-inset);
    text-decoration: none;
    color: inherit;
    flex-shrink: 0;
    height: 160px;
    scroll-snap-align: start;
    transition: border-color var(--duration-fast) var(--ease-out-quart),
                transform var(--duration-fast) var(--ease-out-quart);
  }

  /* Image tiles: square. Doc tiles: portrait page ratio (US Letter). */
  .gallery-image {
    aspect-ratio: 1 / 1;
  }

  .gallery-doc {
    aspect-ratio: 8.5 / 11;
  }

  /* Prev/next buttons — small circular controls overlaid on the gallery,
     fading in on wrapper hover. */
  .gallery-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-text-primary);
    font: inherit;
    font-size: var(--text-sm);
    line-height: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    opacity: 0;
    z-index: 1;
    transition: opacity var(--duration-fast) var(--ease-out-quart),
                border-color var(--duration-fast) var(--ease-out-quart);
  }

  .gallery-wrapper:hover .gallery-nav,
  .gallery-nav:focus-visible {
    opacity: 1;
  }

  .gallery-nav:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .gallery-nav-prev {
    left: -6px;
  }

  .gallery-nav-next {
    right: -6px;
  }

  .gallery-item:hover,
  .gallery-item:focus-visible {
    border-color: var(--color-accent);
    transform: translateY(-1px);
  }

  .gallery-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .gallery-doc {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    padding: var(--space-3);
    text-align: center;
  }

  .doc-icon {
    background: var(--color-accent);
    color: var(--color-bone);
    padding: 0.15em 0.5em;
    border-radius: var(--radius-sm);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-loose);
  }

  .doc-label {
    color: var(--color-text-primary);
    font-size: var(--text-sm);
  }

  /* Video tile: 16:9 to read as video-shaped. Two visual modes — when a YouTube
     thumbnail is available the poster fills the tile and the play button + label
     overlay it; otherwise the tile renders like the PDF doc, with a clay
     play-arrow badge centered above the label. */
  .gallery-video {
    aspect-ratio: 16 / 9;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    padding: var(--space-3);
    text-align: center;
  }

  .gallery-video .video-play {
    background: var(--color-accent);
    color: var(--color-bone);
    padding: 0.15em 0.6em;
    border-radius: var(--radius-sm);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-loose);
    line-height: 1;
  }

  .gallery-video .video-label {
    color: var(--color-text-primary);
    font-size: var(--text-sm);
  }

  .video-thumb {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    z-index: 0;
  }

  /* Thumbnail mode: poster fills the tile; play button becomes a round white
     dot center-overlaid; label moves into a subtle dark gradient strip at the
     bottom for readability against arbitrary thumbnail content. */
  .gallery-video.has-thumb {
    justify-content: flex-end;
    padding: 0;
    gap: 0;
  }

  .gallery-video.has-thumb .video-play {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 38px;
    height: 38px;
    padding: 0;
    border-radius: 50%;
    background: rgba(245, 241, 234, 0.94);
    color: var(--color-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    letter-spacing: 0;
    z-index: 2;
    transition: transform var(--duration-fast) var(--ease-out-quart);
  }

  .gallery-video.has-thumb:hover .video-play,
  .gallery-video.has-thumb:focus-visible .video-play {
    transform: translate(-50%, -50%) scale(1.08);
  }

  .gallery-video.has-thumb .video-label {
    position: relative;
    z-index: 2;
    width: 100%;
    margin: 0;
    padding: var(--space-6) var(--space-3) var(--space-2);
    color: var(--color-bone);
    background: linear-gradient(to top, rgba(44, 36, 22, 0.78), rgba(44, 36, 22, 0));
    box-sizing: border-box;
    text-align: left;
  }

  .detail-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3) var(--space-6);
