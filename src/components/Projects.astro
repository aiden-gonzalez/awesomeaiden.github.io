---
import projects from '../data/projects.json';
import { projectShapes, PROJECT_SHAPE_VIEW } from '../lib/project-shapes';

type Project = {
  title: string;
  period: string;
  description: string;
  stack: string[];
  link?: string;
  status: 'active' | 'completed';
  shape: keyof typeof projectShapes;
};

const cards = projects as Project[];
---

<section class="projects" id="projects">
  <header class="projects-header">
    <p class="label-mono">selected work · 2020 → present</p>
  </header>

  <ul class="projects-grid">
    {cards.map((c) => {
      const shape = projectShapes[c.shape] ?? projectShapes.line;
      const Wrapper = c.link ? 'a' : 'article';
      const wrapperProps = c.link
        ? { href: c.link, target: '_blank', rel: 'noopener noreferrer' }
        : {};
      return (
        <li>
          <Wrapper class="card" {...wrapperProps}>
            <div class="card-top">
              <p class="card-period label-mono">{c.period}</p>

              <svg
                class="card-map"
                viewBox={`0 0 ${PROJECT_SHAPE_VIEW.width} ${PROJECT_SHAPE_VIEW.height}`}
                preserveAspectRatio="xMidYMid meet"
                aria-hidden="true"
                role="img"
              >
                <path class="map-line" d={shape.path} fill="none" />
                {shape.dots.map((d) => (
                  <circle class="map-dot" cx={d.x} cy={d.y} r="3" />
                ))}
              </svg>
            </div>

            <h3 class="card-title">{c.title}</h3>
            <p class="card-desc">{c.description}</p>

            <ul class="card-stack">
              {c.stack.map((s) => <li class="stack-tag label-mono">{s}</li>)}
            </ul>
          </Wrapper>
        </li>
      );
    })}
  </ul>
</section>

<style>
  .projects {
    background: var(--color-bg);
    padding: var(--space-16) var(--space-4);
  }

  @media (min-width: 768px) {
    .projects {
      padding: var(--space-24) var(--space-8);
    }
  }

  .projects-header,
  .projects-grid {
    max-width: var(--max-width-wide);
    margin-left: auto;
    margin-right: auto;
  }

  .projects-header p {
    color: var(--color-text-secondary);
    margin: 0;
  }

  .projects-grid {
    list-style: none;
    padding: 0;
    margin: var(--space-12) auto 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  @media (min-width: 800px) {
    .projects-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .projects-grid > li {
    display: flex;
  }

  /* Card */
  .card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    width: 100%;
    color: inherit;
    text-decoration: none;
    transition: border-color var(--duration-fast) var(--ease-out-quart),
                transform var(--duration-fast) var(--ease-out-quart);
  }

  a.card:hover,
  a.card:focus-visible {
    border-color: var(--color-accent);
    transform: translateY(-2px);
  }

  .card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
  }

  .card-period {
    color: var(--color-text-secondary);
  }

  .card-map {
    width: 120px;
    height: 40px;
    flex-shrink: 0;
  }

  @media (min-width: 480px) {
    .card-map {
      width: 160px;
      height: 54px;
    }
  }

  .map-line {
    stroke: var(--color-text-secondary);
    stroke-width: 1.75;
    stroke-linejoin: round;
    stroke-linecap: round;
    vector-effect: non-scaling-stroke;
  }

  .map-dot {
    fill: var(--color-text-secondary);
  }

  /* Card text */
  .card-title {
    font-size: var(--text-xl);
    color: var(--color-text-primary);
    margin: 0;
  }

  .card-desc {
    color: var(--color-text-primary);
    line-height: var(--leading-normal);
    margin: 0;
  }

  /* Stack tags */
  .card-stack {
    list-style: none;
    padding: var(--space-4) 0 0;
    margin: var(--space-2) 0 0;
    border-top: 1px dashed var(--color-border);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-3);
  }

  .stack-tag {
    color: var(--color-text-secondary);
  }

  .stack-tag:not(:last-child)::after {
    content: ' ·';
    color: var(--color-text-tertiary);
  }
</style>
