---
type Channel =
  | { label: string; value: string; copy: string }
  | { label: string; value: string; href: string };

const channels: Channel[] = [
  { label: 'Email',    value: 'aidenlgonzalez2@gmail.com',                copy: 'aidenlgonzalez2@gmail.com' },
  { label: 'GitHub',   value: 'github.com/aiden-gonzalez',                href: 'https://github.com/aiden-gonzalez' },
  { label: 'LinkedIn', value: 'linkedin.com/in/aiden-gonzalez-712a26170', href: 'https://www.linkedin.com/in/aiden-gonzalez-712a26170/' },
];
---

<section class="register" id="register">
  <header class="reg-header">
    <p class="label-mono">contact</p>
    <p class="label-mono reg-elev">elevation · 14,410 ft</p>
  </header>

  <div class="reg-grid">
    <div class="reg-main">
      <form
        class="reg-form"
        action="mailto:aidenlgonzalez2@gmail.com"
        method="post"
        enctype="text/plain"
      >
        <label class="field">
          <span class="field-label label-mono">Your name</span>
          <input class="field-input" type="text" name="Name" placeholder="Hiker" required />
        </label>

        <label class="field">
          <span class="field-label label-mono">How to reach you</span>
          <input class="field-input" type="text" name="Reach" placeholder="email or @handle" required />
        </label>

        <label class="field">
          <span class="field-label label-mono">A note</span>
          <textarea class="field-input field-textarea" name="Note" rows="4" placeholder="Say hello, ask a question, or just sign in." required></textarea>
        </label>

        <button class="reg-submit label-mono" type="submit">submit</button>
      </form>
    </div>

    <div class="reg-aside">
      <aside class="reg-channels">
        <p class="label-mono channels-title">direct channels</p>
        <ul class="channels-list">
          {channels.map((c) => (
            <li class="channel">
              <span class="channel-label label-mono">{c.label}</span>
              {'href' in c ? (
                <a class="channel-value" href={c.href} target="_blank" rel="noopener noreferrer">{c.value}</a>
              ) : (
                <button
                  class="channel-value channel-copy"
                  type="button"
                  data-copy={c.copy}
                  aria-label={`Copy ${c.value} to clipboard`}
                >
                  <span class="channel-text">{c.value}</span>
                  <span class="channel-hover" aria-hidden="true">click to copy</span>
                </button>
              )}
            </li>
          ))}
        </ul>
      </aside>

      <figure class="reg-mountain" aria-labelledby="rainier-title rainier-desc">
        <svg
          class="rainier"
          viewBox="0 0 600 220"
          preserveAspectRatio="xMidYEnd meet"
          role="img"
        >
          <title id="rainier-title">Mount Rainier</title>
          <desc id="rainier-desc">A stylised line drawing of Mount Rainier with Liberty Cap rising to the left of the main summit, snow detail on the upper slopes, two distant atmospheric ridges behind, and subtle cleaver lines suggesting the rocky ridges between glaciers.</desc>

          <!-- Atmospheric ridges behind — distant Cascade peaks. -->
          <path
            class="rainier-far"
            fill="none"
            d="M 0,172 Q 80,168 160,173 T 320,170 T 480,172 T 600,170"
          />
          <path
            class="rainier-ridge"
            fill="none"
            d="M 0,160 C 80,156 160,165 240,158 C 320,152 400,162 480,156 C 540,152 580,158 600,156"
          />

          <!-- Mount Rainier: broad asymmetric silhouette.  Liberty Cap appears as a small
               summit just left of the main Columbia Crest plateau, with a slight saddle
               between them. -->
          <path
            class="rainier-main"
            fill="none"
            d="M 20,205
               C 80,200 130,192 170,178
               C 195,162 215,140 230,118
               C 232,112 237,108 240,108
               L 252,108
               C 256,108 260,111 262,113
               C 268,118 272,118 278,113
               C 282,108 290,100 300,96
               L 305,95
               L 355,95
               C 365,96 372,100 380,108
               C 410,128 445,154 480,174
               C 520,188 555,198 585,202
               L 595,205"
          />

          <!-- Cleaver lines: subtle interior strokes suggesting rocky ridges between glaciers. -->
          <path class="rainier-cleaver" fill="none" d="M 295,102 C 290,135 286,165 282,195" />
          <path class="rainier-cleaver" fill="none" d="M 345,100 C 354,132 365,162 378,195" />

          <!-- Snow band on the upper slopes. -->
          <path
            class="rainier-snow"
            fill="none"
            d="M 246,124 C 272,116 308,113 338,114 C 362,115 378,119 388,126"
          />
          <path
            class="rainier-snow-soft"
            fill="none"
            d="M 262,148 C 292,141 322,140 352,143 C 376,145 392,151 402,158"
          />

          <!-- Ground -->
          <line class="rainier-ground" fill="none" x1="0" y1="208" x2="600" y2="208" />
        </svg>
      </figure>
    </div>
  </div>

  <footer class="reg-footer">
    <p class="label-mono">end of route</p>
  </footer>
</section>

<script>
  // Copy-to-clipboard for channel buttons with [data-copy].  Briefly swaps the label
  // to "Copied!" so the user gets visual confirmation.
  document.querySelectorAll<HTMLButtonElement>('button[data-copy]').forEach((btn) => {
    const text = btn.querySelector<HTMLElement>('.channel-text');
    if (!text) return;
    const original = text.textContent;
    let timer: number | undefined;
    btn.addEventListener('click', async () => {
      const payload = btn.dataset.copy;
      if (!payload) return;
      try {
        await navigator.clipboard.writeText(payload);
        text.textContent = 'copied to clipboard';
        btn.classList.add('copied');
        if (timer) window.clearTimeout(timer);
        timer = window.setTimeout(() => {
          text.textContent = original;
          btn.classList.remove('copied');
        }, 1500);
      } catch (err) {
        console.warn('Copy failed', err);
      }
    });
  });
</script>

<style>
  .register {
    background: var(--color-surface-inset);
    border-top: 1px solid var(--color-border);
    padding: var(--space-16) var(--space-4);
  }

  @media (min-width: 768px) {
    .register {
      padding: var(--space-24) var(--space-8);
    }
  }

  .reg-header,
  .reg-grid,
  .reg-footer {
    max-width: var(--max-width-wide);
    margin-left: auto;
    margin-right: auto;
  }

  .reg-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .reg-header .label-mono {
    color: var(--color-text-secondary);
  }

  .reg-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
    margin-top: var(--space-12);
  }

  @media (min-width: 900px) {
    .reg-grid {
      grid-template-columns: minmax(0, 1.6fr) minmax(0, 1fr);
      gap: var(--space-16);
    }
  }

  /* Form */
  .reg-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .field-label {
    color: var(--color-text-secondary);
  }

  .field-input {
    font-family: var(--font-sans);
    /* 16px minimum prevents iOS Safari from zooming the viewport on focus. */
    font-size: 1rem;
    color: var(--color-text-primary);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: var(--space-3) var(--space-4);
    line-height: var(--leading-normal);
  }

  .field-input:focus {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
    border-color: var(--color-accent);
  }

  .field-textarea {
    font-family: var(--font-sans);
    resize: vertical;
    min-height: 6rem;
  }

  .reg-submit {
    align-self: start;
    background: var(--color-accent);
    color: var(--color-bg);
    border: 1px solid var(--color-accent);
    border-radius: var(--radius-sm);
    padding: var(--space-3) var(--space-6);
    cursor: pointer;
    transition: background-color var(--duration-fast) var(--ease-out-quart),
                color var(--duration-fast) var(--ease-out-quart);
  }

  .reg-submit:hover,
  .reg-submit:focus-visible {
    background: var(--color-bg);
    color: var(--color-accent);
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  /* Aside: mountain + channels stacked in the right column */
  .reg-aside {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  /* Mountain */
  .reg-mountain {
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
  }

  .rainier {
    width: 100%;
    max-width: 320px;
    height: auto;
    display: block;
  }

  .rainier path,
  .rainier line {
    vector-effect: non-scaling-stroke;
    stroke-linejoin: round;
    stroke-linecap: round;
  }

  .rainier-far {
    stroke: var(--color-forest-faint);
    stroke-width: 0.8;
  }

  .rainier-ridge {
    stroke: var(--color-forest-faint);
    stroke-width: 1;
  }

  .rainier-main {
    stroke: var(--color-forest);
    stroke-width: 1.5;
  }

  .rainier-cleaver {
    stroke: var(--color-forest-faint);
    stroke-width: 0.9;
  }

  .rainier-snow {
    stroke: var(--color-forest-soft);
    stroke-width: 1.25;
  }

  .rainier-snow-soft {
    stroke: var(--color-forest-faint);
    stroke-width: 1;
  }

  .rainier-ground {
    stroke: var(--color-border);
    stroke-width: 1;
  }

  /* Channels panel */
  .reg-channels {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-6);
  }

  .channels-title {
    color: var(--color-text-secondary);
    margin: 0 0 var(--space-6);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--color-border);
  }

  .channels-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .channel {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .channel-label {
    color: var(--color-text-secondary);
  }

  .channel-value {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-text-primary);
    text-decoration: none;
    word-break: break-all;
  }

  .channel-value:hover,
  .channel-value:focus-visible {
    color: var(--color-accent);
    text-decoration: underline;
  }

  /* The copy button needs button-default resets to look like the sibling link.
     The button has two layered labels: the value text (default visible) and a
     "click to copy" hint (default hidden) that fades in on hover/focus. */
  button.channel-value {
    background: none;
    border: none;
    padding: 0;
    margin: 0;
    cursor: pointer;
    text-align: left;
    font: inherit;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    position: relative;
  }

  .channel-text,
  .channel-hover {
    transition: opacity var(--duration-fast) var(--ease-out-quart);
  }

  .channel-hover {
    position: absolute;
    inset: 0;
    opacity: 0;
    pointer-events: none;
  }

  button.channel-value:hover .channel-text,
  button.channel-value:focus-visible .channel-text {
    opacity: 0;
  }

  button.channel-value:hover .channel-hover,
  button.channel-value:focus-visible .channel-hover {
    opacity: 1;
    color: var(--color-accent);
  }

  /* The shared .channel-value rule underlines on hover/focus.  Buttons swap text
     instead, so no underline is needed. */
  button.channel-value:hover,
  button.channel-value:focus-visible {
    text-decoration: none;
  }

  /* While the "copied" message is showing, keep the value text visible and the
     hover label hidden even if the cursor is still over the button. */
  button.channel-value.copied {
    color: var(--color-accent);
  }

  button.channel-value.copied .channel-text {
    opacity: 1;
  }

  button.channel-value.copied .channel-hover {
    opacity: 0;
  }

  /* Footer */
  .reg-footer {
    margin-top: var(--space-16);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border);
    text-align: center;
  }

  .reg-footer .label-mono {
    color: var(--color-text-secondary);
  }
</style>
