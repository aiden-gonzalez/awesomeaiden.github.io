---
const channels = [
  { label: 'Email',    value: 'aidenlgonzalez2@gmail.com',                href: 'mailto:aidenlgonzalez2@gmail.com' },
  { label: 'GitHub',   value: 'github.com/aiden-gonzalez',                href: 'https://github.com/aiden-gonzalez' },
  { label: 'LinkedIn', value: 'linkedin.com/in/aiden-gonzalez-712a26170', href: 'https://www.linkedin.com/in/aiden-gonzalez-712a26170/' },
  { label: 'Site',     value: 'aidengonzalez.dev',                       href: 'https://aidengonzalez.dev' },
];
---

<section class="register" id="register">
  <header class="reg-header">
    <p class="label-mono">contact</p>
    <p class="label-mono reg-elev">elevation · 14,410 ft</p>
  </header>

  <div class="reg-grid">
    <div class="reg-main">
      <form
        class="reg-form"
        action="mailto:aidenlgonzalez2@gmail.com"
        method="post"
        enctype="text/plain"
      >
        <label class="field">
          <span class="field-label label-mono">Your name</span>
          <input class="field-input" type="text" name="Name" placeholder="Hiker" required />
        </label>

        <label class="field">
          <span class="field-label label-mono">How to reach you</span>
          <input class="field-input" type="text" name="Reach" placeholder="email or @handle" required />
        </label>

        <label class="field">
          <span class="field-label label-mono">A note</span>
          <textarea class="field-input field-textarea" name="Note" rows="4" placeholder="Say hello, ask a question, or just sign in." required></textarea>
        </label>

        <button class="reg-submit label-mono" type="submit">submit</button>
      </form>
    </div>

    <div class="reg-aside">
      <aside class="reg-channels">
        <p class="label-mono channels-title">direct channels</p>
        <ul class="channels-list">
          {channels.map((c) => (
            <li class="channel">
              <span class="channel-label label-mono">{c.label}</span>
              <a class="channel-value" href={c.href}>{c.value}</a>
            </li>
          ))}
        </ul>
      </aside>

      <figure class="reg-mountain" aria-labelledby="rainier-title rainier-desc">
        <svg
          class="rainier"
          viewBox="0 0 600 220"
          preserveAspectRatio="xMidYEnd meet"
          role="img"
        >
          <title id="rainier-title">Mount Rainier</title>
          <desc id="rainier-desc">A stylised line drawing of Mount Rainier with a distant ridge behind it and a snow line near the summit.</desc>

          <path
            class="rainier-ridge"
            fill="none"
            d="M 0,165 C 110,160 220,168 330,162 C 440,156 530,164 600,160"
          />
          <path
            class="rainier-main"
            fill="none"
            d="M 30,198
               C 110,192 175,180 230,150
               C 260,134 285,112 310,90
               Q 330,78 350,88
               C 375,102 400,128 430,158
               C 480,180 540,194 580,198"
          />
          <path
            class="rainier-snow"
            fill="none"
            d="M 265,135 C 295,118 325,113 350,118 C 370,121 385,134 395,148"
          />
          <line class="rainier-ground" fill="none" x1="0" y1="205" x2="600" y2="205" />
        </svg>
      </figure>
    </div>
  </div>

  <footer class="reg-footer">
    <p class="label-mono">end of route · thanks for riding</p>
  </footer>
</section>

<style>
  .register {
    background: var(--color-surface-inset);
    border-top: 1px solid var(--color-border);
    padding: var(--space-16) var(--space-4);
  }

  @media (min-width: 768px) {
    .register {
      padding: var(--space-24) var(--space-8);
    }
  }

  .reg-header,
  .reg-grid,
  .reg-footer {
    max-width: var(--max-width-wide);
    margin-left: auto;
    margin-right: auto;
  }

  .reg-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .reg-header .label-mono {
    color: var(--color-text-secondary);
  }

  .reg-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
    margin-top: var(--space-12);
  }

  @media (min-width: 900px) {
    .reg-grid {
      grid-template-columns: minmax(0, 1.6fr) minmax(0, 1fr);
      gap: var(--space-16);
    }
  }

  /* Form */
  .reg-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .field-label {
    color: var(--color-text-secondary);
  }

  .field-input {
    font-family: var(--font-sans);
    /* 16px minimum prevents iOS Safari from zooming the viewport on focus. */
    font-size: 1rem;
    color: var(--color-text-primary);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: var(--space-3) var(--space-4);
    line-height: var(--leading-normal);
  }

  .field-input:focus {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
    border-color: var(--color-accent);
  }

  .field-textarea {
    font-family: var(--font-sans);
    resize: vertical;
    min-height: 6rem;
  }

  .reg-submit {
    align-self: start;
    background: var(--color-accent);
    color: var(--color-bg);
    border: 1px solid var(--color-accent);
    border-radius: var(--radius-sm);
    padding: var(--space-3) var(--space-6);
    cursor: pointer;
    transition: background-color var(--duration-fast) var(--ease-out-quart),
                color var(--duration-fast) var(--ease-out-quart);
  }

  .reg-submit:hover,
  .reg-submit:focus-visible {
    background: var(--color-bg);
    color: var(--color-accent);
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  /* Aside: mountain + channels stacked in the right column */
  .reg-aside {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  /* Mountain */
  .reg-mountain {
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
  }

  .rainier {
    width: 100%;
    max-width: 320px;
    height: auto;
    display: block;
  }

  .rainier path,
  .rainier line {
    vector-effect: non-scaling-stroke;
    stroke-linejoin: round;
    stroke-linecap: round;
  }

  .rainier-ridge {
    stroke: var(--color-forest-faint);
    stroke-width: 1;
  }

  .rainier-main {
    stroke: var(--color-forest);
    stroke-width: 1.5;
  }

  .rainier-snow {
    stroke: var(--color-forest-soft);
    stroke-width: 1;
  }

  .rainier-ground {
    stroke: var(--color-border);
    stroke-width: 1;
  }

  /* Channels panel */
  .reg-channels {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-6);
  }

  .channels-title {
    color: var(--color-text-secondary);
    margin: 0 0 var(--space-6);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--color-border);
  }

  .channels-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .channel {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .channel-label {
    color: var(--color-text-secondary);
  }

  .channel-value {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-text-primary);
    text-decoration: none;
    word-break: break-all;
  }

  .channel-value:hover,
  .channel-value:focus-visible {
    color: var(--color-accent);
    text-decoration: underline;
  }

  /* Footer */
  .reg-footer {
    margin-top: var(--space-16);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border);
    text-align: center;
  }

  .reg-footer .label-mono {
    color: var(--color-text-secondary);
  }
</style>
