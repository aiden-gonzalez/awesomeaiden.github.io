---
type Channel =
  | { label: string; value: string; copy: string }
  | { label: string; value: string; href: string }
  | { label: string; value: string; download: string };

const channels: Channel[] = [
  { label: 'Email',    value: 'aidenlgonzalez2@gmail.com',                copy: 'aidenlgonzalez2@gmail.com' },
  { label: 'GitHub',   value: 'github.com/aiden-gonzalez',                href: 'https://github.com/aiden-gonzalez' },
  { label: 'LinkedIn', value: 'linkedin.com/in/aiden-gonzalez-712a26170', href: 'https://www.linkedin.com/in/aiden-gonzalez-712a26170/' },
  { label: 'Resume',   value: 'aiden_gonzalez_resume.pdf',                 download: '/files/aiden_gonzalez_resume.pdf' },
];
---

<section class="contact" id="contact">
  <header class="contact-header">
    <p class="label-mono">contact</p>
    <p class="label-mono contact-elev">elevation · 14,410 ft</p>
  </header>

  <div class="contact-grid">
    <aside class="contact-channels">
      <ul class="channels-list">
        {channels.map((c) => (
          <li class="channel">
            <span class="channel-label label-mono">{c.label}</span>
            {'href' in c ? (
              <a class="channel-value" href={c.href} target="_blank" rel="noopener noreferrer">{c.value}</a>
            ) : 'download' in c ? (
              <a class="channel-value" href={c.download} download>{c.value}</a>
            ) : (
              <button
                class="channel-value channel-copy"
                type="button"
                data-copy={c.copy}
                aria-label={`Copy ${c.value} to clipboard`}
              >
                <span class="channel-text">{c.value}</span>
                <span class="channel-hover" aria-hidden="true">click to copy</span>
              </button>
            )}
          </li>
        ))}
      </ul>
    </aside>

      <figure class="contact-cup">
        <svg
          class="cup"
          viewBox="104 80 212 212"
          preserveAspectRatio="xMidYMid meet"
          role="img"
          aria-label="A cup of espresso with steam, viewed from the side"
        >
          <!-- Steam rising off the cup. -->
          <path class="cup-steam" fill="none" d="M 196,170 C 185,154 207,138 196,122" />
          <path class="cup-steam" fill="none" d="M 224,170 C 213,154 235,138 224,122" />

          <!-- Saucer. -->
          <ellipse class="cup-line" cx="210" cy="238" rx="98" ry="15" fill="none" />
          <path class="cup-line" fill="none" d="M 124,240 Q 210,260 296,240" />

          <!-- Cup body (seated low in the saucer), rim opening, crema surface, and handle.
               The handle is a closed loop returning to the cup wall at both ends. -->
          <path class="cup-line" fill="none" d="M 154,177 C 158,202 168,218 180,232 Q 210,239 240,232 C 252,218 262,202 266,177" />
          <ellipse class="cup-line" cx="210" cy="177" rx="56" ry="12" fill="none" />
          <ellipse class="cup-crema" cx="210" cy="177" rx="45" ry="8" fill="none" />
          <path class="cup-line" fill="none" d="M 264,186 C 297,182 301,217 250,218" />
        </svg>
      </figure>
  </div>

  <footer class="contact-footer">
    <p class="label-mono">end of route</p>
  </footer>
</section>

<script>
  // Copy-to-clipboard for channel buttons with [data-copy].  Briefly swaps the label
  // to "Copied!" so the user gets visual confirmation.
  document.querySelectorAll<HTMLButtonElement>('button[data-copy]').forEach((btn) => {
    const text = btn.querySelector<HTMLElement>('.channel-text');
    if (!text) return;
    const original = text.textContent;
    let timer: number | undefined;
    btn.addEventListener('click', async () => {
      const payload = btn.dataset.copy;
      if (!payload) return;
      try {
        await navigator.clipboard.writeText(payload);
        text.textContent = 'copied to clipboard';
        btn.classList.add('copied');
        if (timer) window.clearTimeout(timer);
        timer = window.setTimeout(() => {
          text.textContent = original;
          btn.classList.remove('copied');
        }, 1500);
      } catch (err) {
        console.warn('Copy failed', err);
      }
    });
  });
</script>

<style>
  .contact {
    background: var(--color-surface-inset);
    border-top: 1px solid var(--color-border);
    padding: var(--space-16) var(--space-4);
  }

  @media (min-width: 768px) {
    .contact {
      padding: var(--space-24) var(--space-8);
    }
  }

  .contact-header,
  .contact-grid,
  .contact-footer {
    max-width: var(--max-width-wide);
    margin-left: auto;
    margin-right: auto;
  }

  .contact-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .contact-header .label-mono {
    color: var(--color-text-secondary);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-10);
    margin-top: var(--space-12);
    align-items: center;
  }

  @media (min-width: 900px) {
    .contact-grid {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      gap: var(--space-16);
    }
  }

  /* Espresso cup */
  .contact-cup {
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
  }

  .cup {
    width: 100%;
    max-width: 360px;
    height: auto;
    display: block;
  }

  .cup path,
  .cup ellipse {
    vector-effect: non-scaling-stroke;
    stroke-linejoin: round;
    stroke-linecap: round;
  }

  .cup-line {
    stroke: var(--color-text-primary);
    stroke-width: 2.2;
  }

  .cup-steam {
    stroke: var(--color-text-tertiary);
    stroke-width: 2;
  }

  .cup-crema {
    stroke: var(--color-text-tertiary);
    stroke-width: 1.8;
  }

  /* Channels panel */
  .contact-channels {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-6);
  }

  .channels-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .channel {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .channel-label {
    color: var(--color-text-secondary);
  }

  .channel-value {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-text-primary);
    text-decoration: none;
    word-break: break-all;
  }

  .channel-value:hover,
  .channel-value:focus-visible {
    color: var(--color-accent);
    text-decoration: underline;
  }

  /* The copy button needs button-default resets to look like the sibling link.
     The button has two layered labels: the value text (default visible) and a
     "click to copy" hint (default hidden) that fades in on hover/focus. */
  button.channel-value {
    background: none;
    border: none;
    padding: 0;
    margin: 0;
    cursor: pointer;
    text-align: left;
    font: inherit;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    position: relative;
  }

  .channel-text,
  .channel-hover {
    transition: opacity var(--duration-fast) var(--ease-out-quart);
  }

  .channel-hover {
    position: absolute;
    inset: 0;
    opacity: 0;
    pointer-events: none;
  }

  button.channel-value:hover .channel-text,
  button.channel-value:focus-visible .channel-text {
    opacity: 0;
  }

  button.channel-value:hover .channel-hover,
  button.channel-value:focus-visible .channel-hover {
    opacity: 1;
    color: var(--color-accent);
  }

  /* The shared .channel-value rule underlines on hover/focus.  Buttons swap text
     instead, so no underline is needed. */
  button.channel-value:hover,
  button.channel-value:focus-visible {
    text-decoration: none;
  }

  /* While the "copied" message is showing, keep the value text visible and the
     hover label hidden even if the cursor is still over the button. */
  button.channel-value.copied {
    color: var(--color-accent);
  }

  button.channel-value.copied .channel-text {
    opacity: 1;
  }

  button.channel-value.copied .channel-hover {
    opacity: 0;
  }

  /* Footer */
  .contact-footer {
    margin-top: var(--space-16);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border);
    text-align: center;
  }

  .contact-footer .label-mono {
    color: var(--color-text-secondary);
  }
</style>
